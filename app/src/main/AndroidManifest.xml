<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".CodeLabApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.CodeLab"
        tools:targetApi="33">

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.auth.LoginActivity"/>

        <activity
            android:name=".ui.auth.OAuthCallbackActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:noHistory="true">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="codelab" android:host="oauth"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <activity android:name=".ui.PlaygroundActivity"
            android:exported="false" android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.lesson.LessonActivity"
            android:exported="false" android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.market.MarketplaceActivity"
            android:exported="false" android:label="@string/title_marketplace"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.profile.ProfileEditActivity"
            android:exported="false" android:label="@string/title_edit_profile"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.settings.SettingsActivity"
            android:exported="false" android:label="@string/title_settings"
            android:parentActivityName=".ui.MainActivity"/>
    </application>
</manifest>
