<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">
        <ImageView
            android:id="@+id/btnLessonBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null"/>
        <TextView
            android:id="@+id/lessonHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lesson 4"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
        <TextView
            android:id="@+id/stepText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 3 of 5"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>
    </LinearLayout>

    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="60"
        android:progressDrawable="@drawable/progress_horizontal"/>

    <!-- Task callout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_task_callout"
        android:padding="14dp"
        android:layout_marginTop="14dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_task"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:textSize="11sp"
            android:letterSpacing="0.15"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Declare an integer variable named score and assign it the value 100. Then print it using System.out.println()."
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:paddingTop="6dp"/>
    </LinearLayout>

    <!-- Hint callout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card_alt"
        android:padding="12dp"
        android:layout_marginTop="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hint: Use int score = 100; to declare and assign."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingStart="8dp"/>
    </LinearLayout>

    <!-- Code editor (same style) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_editor"
        android:padding="10dp"
        android:layout_marginTop="12dp">
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/lessonLineNumbers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="28dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:gravity="end|top"
                    android:paddingEnd="8dp"/>
                <EditText
                    android:id="@+id/lessonEditor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:textColorHighlight="@color/accent_translucent"
                    android:gravity="start|top"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:minLines="8"
                    android:importantForAutofill="no"/>
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Run & Submit buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">
        <LinearLayout
            android:id="@+id/btnLessonRun"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_button_outline"
            android:gravity="center"
            android:padding="12dp"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶  Run"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/btnLessonSubmit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_button_accent"
            android:gravity="center"
            android:padding="12dp"
            android:orientation="horizontal"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➤  Submit"
                android:textColor="@color/text_on_accent"
                android:textStyle="bold"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Output -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="12dp"
        android:layout_marginTop="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_output"
                android:textColor="@color/text_muted"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.15"/>
            <TextView
                android:id="@+id/lessonStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textColor="@color/success"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <TextView
            android:id="@+id/lessonOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:paddingTop="6dp"
            android:minLines="3"
            android:textIsSelectable="true"/>
    </LinearLayout>
</LinearLayout>
