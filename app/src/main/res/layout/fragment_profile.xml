<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header: Profile + Settings gear -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_profile"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"/>
            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle"
                android:padding="9dp"
                android:src="@drawable/ic_settings"
                android:clickable="true" android:focusable="true"
                android:contentDescription="@null"/>
        </LinearLayout>

        <!-- Avatar with initial letter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="16dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_circle_accent"/>
                <TextView
                    android:id="@+id/avatarInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    tools:text="C"/>
            </FrameLayout>

            <TextView
                android:id="@+id/profileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                tools:text="Coder"/>
            <TextView
                android:id="@+id/profileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:paddingTop="2dp"
                tools:text="coder@device"/>
            <TextView
                android:id="@+id/profileBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_accent"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="8dp"
                tools:text="Free Tier"/>
        </LinearLayout>

        <!-- 3-stat grid: Projects / Runs / Lessons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/statProjects"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="0"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Projects"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginHorizontal="4dp">
                <TextView
                    android:id="@+id/statRuns"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="0"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Runs"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginStart="4dp">
                <TextView
                    android:id="@+id/statLessons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="0"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lessons"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Account Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/menuEditProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit Profile"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Change Password"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuSyncData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sync Data"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuManageDevices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage Devices"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delete Account"
                android:textColor="@color/error"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <!-- App Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APP"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/menuEditorSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editor Settings"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuStorage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Storage &amp; Cache"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About CodeAPP"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_primary"/>
            <TextView
                android:id="@+id/menuSignOut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textColor="@color/error"
                android:textSize="14sp"
                android:padding="14dp"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
