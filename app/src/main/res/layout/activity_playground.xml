<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e1e1e">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar: lang badge + action buttons + folder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#252526"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/langBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ Java"
                android:textColor="#f0a500"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/bg_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/btnUndo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="6dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Undo"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnSave"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="6dp"
                android:src="@drawable/ic_file"
                android:contentDescription="Save"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnCopy"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="6dp"
                android:src="@drawable/ic_code"
                android:contentDescription="Copy"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnShare"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="6dp"
                android:src="@drawable/ic_link"
                android:contentDescription="Share"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnFolder"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="6dp"
                android:src="@drawable/ic_file"
                android:contentDescription="Explorer"
                android:layout_marginStart="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- File tabs row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#252526"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/fileTabsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="4dp">

                <!-- File tabs injected dynamically -->
                <LinearLayout
                    android:id="@+id/fileTab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1e1e1e"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_file"
                        android:contentDescription="@null"/>
                    <TextView
                        android:id="@+id/fileTabLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Main.java"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:paddingStart="6dp"/>
                    <TextView
                        android:id="@+id/fileTabClose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="×"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:paddingStart="8dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnNew"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textColor="@color/text_muted"
                    android:textSize="18sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Editor area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1e1e1e">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/lineNumbers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="28dp"
                        android:fontFamily="monospace"
                        android:textColor="#5a6270"
                        android:textSize="12sp"
                        android:gravity="end|top"
                        android:paddingEnd="10dp"/>
                    <EditText
                        android:id="@+id/codeEditor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:textColor="#d4d4d4"
                        android:textColorHighlight="@color/accent_translucent"
                        android:gravity="start|top"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:minLines="15"
                        android:importantForAutofill="no"
                        android:textColorHint="#5a6270"/>
                </LinearLayout>
            </ScrollView>
        </FrameLayout>

        <!-- VS Code status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#007acc"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/statusLang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ Java"
                android:textColor="#ffffff"
                android:textSize="10sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="#ffffff88"
                android:textSize="10sp"/>
            <TextView
                android:id="@+id/statusLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ln 1, Col 1"
                android:textColor="#ffffff"
                android:textSize="10sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · UTF-8"
                android:textColor="#ffffff"
                android:textSize="10sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/statusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textColor="#ffffff"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/btnToggleConsole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Console"
                android:textColor="#ffffffdd"
                android:textSize="10sp"
                android:paddingStart="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Console panel -->
        <LinearLayout
            android:id="@+id/consolePanel"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:orientation="vertical"
            android:background="#1e1e1e"
            android:visibility="visible">

            <!-- Console header with tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#252526"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/consTabOutput"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Output"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingEnd="14dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/consTabProblems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Problems"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:clickable="true"
                    android:focusable="true"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/btnClearConsole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:paddingEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnCloseConsole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Console body -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp">
                <TextView
                    android:id="@+id/outputView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="#d4d4d4"
                    android:textSize="11sp"
                    android:textIsSelectable="true"
                    android:text="// Press ▶ Run to execute"/>
            </ScrollView>
        </LinearLayout>

        <!-- Floating Run button -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btnRun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:text="Run"
            android:textColor="#000000"
            android:textStyle="bold"
            app:icon="@drawable/ic_play_small"
            app:iconTint="#000000"
            app:backgroundTint="@color/accent"
            app:elevation="8dp"/>
    </LinearLayout>

    <!-- File explorer drawer -->
    <LinearLayout
        android:id="@+id/explorerDrawer"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_card">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Explorer"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <ImageView
                android:id="@+id/btnCloseDrawer"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Close"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY PROJECT"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:padding="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/explorerList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"/>

        <LinearLayout
            android:id="@+id/btnNewFileDrawer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ New file"
                android:textColor="@color/text_muted"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
