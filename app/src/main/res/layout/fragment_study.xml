<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_study_mode"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"/>
        <ImageView
            android:id="@+id/btnMarketplace"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle"
            android:padding="9dp"
            android:src="@drawable/ic_marketplace"
            android:clickable="true" android:focusable="true"
            android:contentDescription="@null"/>
    </LinearLayout>

    <!-- Active pack card — populated dynamically -->
    <LinearLayout
        android:id="@+id/activePackCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="16dp"
        android:layout_marginTop="12dp">
        <TextView
            android:id="@+id/activePackTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Java Fundamentals"/>
        <TextView
            android:id="@+id/activePackProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingTop="4dp"
            tools:text="Current track · 0 of 6 lessons completed"/>
        <ProgressBar
            android:id="@+id/activePackProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_horizontal"/>
        <TextView
            android:id="@+id/activePackPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:paddingTop="6dp"
            tools:text="0% complete"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        <TextView
            android:id="@+id/chipAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_all"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_accent"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@drawable/chip_selector"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:id="@+id/chipInProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_in_progress"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@drawable/chip_selector"
            android:layout_marginStart="8dp"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:id="@+id/chipCompleted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_completed"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@drawable/chip_selector"
            android:layout_marginStart="8dp"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_lessons"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginTop="18dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLessons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/emptyLessons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/empty_lessons"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone"/>
</LinearLayout>
